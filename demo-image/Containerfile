# cc-deck demo image
# Pre-built environment with cc-deck, Zellij, and Claude Code.
# Usage:
#   podman run -d --name mydev -e ANTHROPIC_API_KEY=sk-ant-... quay.io/cc-deck/cc-deck-demo:latest
#   podman exec -it mydev zellij --layout cc-deck

ARG BASE_IMAGE=quay.io/rhuss/cc-deck-base:latest
FROM ${BASE_IMAGE}

ARG TARGETARCH

# User setup (ensure zsh shell, writable dirs)
USER root
RUN id coder >/dev/null 2>&1 || useradd -m -s /bin/zsh coder
RUN chsh -s /bin/zsh coder 2>/dev/null || usermod -s /bin/zsh coder
RUN touch /home/coder/.zshrc && chown coder:coder /home/coder/.zshrc

# cc-session (Rust release: arch-unknown-linux-gnu.tar.xz with nested dir)
RUN ARCH=$(uname -m) && \
    curl -fsSL "https://github.com/rhuss/cc-session/releases/latest/download/cc-session-${ARCH}-unknown-linux-gnu.tar.xz" \
      | tar -xJf - --strip-components=1 -C /usr/local/bin "cc-session-${ARCH}-unknown-linux-gnu/cc-session" && \
    chmod +x /usr/local/bin/cc-session

# cc-setup (Go release: version-linux-arch.tar.gz, flat)
ARG CC_SETUP_VERSION=0.3.0
RUN ARCH=$(uname -m) && \
    case "$ARCH" in x86_64) GOARCH=amd64;; aarch64) GOARCH=arm64;; esac && \
    curl -fsSL "https://github.com/rhuss/cc-setup/releases/download/v${CC_SETUP_VERSION}/cc-setup-${CC_SETUP_VERSION}-linux-${GOARCH}.tar.gz" \
      | tar -xzf - -C /usr/local/bin cc-setup && \
    chmod +x /usr/local/bin/cc-setup

# cc-deck self-install (Zellij + plugin + layouts + hooks)
COPY .build-context/cc-deck-linux-${TARGETARCH} /usr/local/bin/cc-deck
RUN chmod +x /usr/local/bin/cc-deck && \
    mkdir -p /home/coder/.claude /home/coder/.cache/zellij && \
    HOME=/home/coder \
    ZELLIJ_CONFIG_DIR=/home/coder/.config/zellij \
    cc-deck plugin install --install-zellij --force --skip-backup && \
    mkdir -p /home/coder/.config/zellij/themes && \
    printf 'default_shell "zsh"\ntheme "claude-dark"\n\nthemes {\n    claude-dark {\n        fg "#E5E5E5"\n        bg "#264F78"\n        black "#2D2D2D"\n        red "#FF6B6B"\n        green "#7EC699"\n        yellow "#E5C07B"\n        blue "#61AFEF"\n        magenta "#C678DD"\n        cyan "#56B6C2"\n        white "#E5E5E5"\n        orange "#D19A66"\n    }\n}\n' > /home/coder/.config/zellij/config.kdl && \
    chown -R coder:coder /home/coder/.config/zellij /home/coder/.cache/zellij /home/coder/.claude && \
    rm -rf /root/.claude /root/.cache/zellij
COPY --chown=coder:coder themes/claude-dark.kdl /home/coder/.config/zellij/themes/claude-dark.kdl

# Claude Code via native installer (bundles its own Node.js runtime)
USER coder
RUN curl -fsSL https://claude.ai/install.sh | sh
USER root
ENV PATH="/home/coder/.local/bin:${PATH}"

USER coder
WORKDIR /home/coder
CMD ["zellij", "--layout", "cc-deck"]
