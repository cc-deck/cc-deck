FROM docker.io/library/alpine:3.21
# Create a fake zellij: sleeps when run as entrypoint, exits cleanly for subcommands.
RUN printf '#!/bin/sh\ncase "$1" in\n  list-sessions) exit 0 ;;\n  delete-session) exit 0 ;;\n  *) exec sleep infinity ;;\nesac\n' > /usr/local/bin/zellij && chmod +x /usr/local/bin/zellij
CMD ["zellij"]
