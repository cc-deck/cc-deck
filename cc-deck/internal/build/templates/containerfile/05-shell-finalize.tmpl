{{- if .ToolPaths}}

# Tool PATH restoration (auto-generated from manifest tools)
RUN for RC in {{.HomeDir}}/.bashrc {{.HomeDir}}/.zshrc; do \
      if [ -f "$RC" ]; then \
        sed -i '1i export PATH="{{range $i, $p := .ToolPaths}}{{if $i}}:{{end}}{{$p}}{{end}}:$PATH"' "$RC"; \
      fi; \
    done
{{- end}}
{{- if eq .Target "openshell"}}

# ============================================================
# FINAL SHELL SETUP (MUST be after all user config COPY/RUN layers)
# ============================================================

# UTF-8 locale (required for correct cursor positioning with multi-byte prompt characters)
# LS_COLORS (required for lsd/ls file-type coloring beyond just directories)
# Note: Ubuntu's dircolors ships without a database, so we set LS_COLORS directly.
RUN for RC in {{.HomeDir}}/.bashrc {{.HomeDir}}/.zshrc; do \
      if [ -f "$RC" ] && ! grep -q 'LANG=' "$RC"; then \
        sed -i '1i export LANG=C.UTF-8' "$RC"; \
      fi; \
      if [ -f "$RC" ] && ! grep -q 'LS_COLORS=' "$RC"; then \
        sed -i '2i export LS_COLORS='"'"'no=00:fi=00:di=00;34:ln=01;36:pi=40;33:so=01;35:do=01;35:bd=40;33;01:cd=40;33;01:or=40;31;01:su=37;41:sg=30;43:tw=30;42:ow=34;42:st=37;44:ex=32:*.tar=01;31:*.tgz=01;31:*.arj=01;31:*.taz=01;31:*.lzh=01;31:*.lzma=01;31:*.zip=01;31:*.z=01;31:*.Z=01;31:*.dz=01;31:*.gz=01;31:*.bz2=01;31:*.xz=01;31:*.jar=01;31:*.rpm=01;31:*.deb=01;31:*.jpg=01;35:*.jpeg=01;35:*.png=01;35:*.gif=01;35:*.svg=01;35:*.mp3=00;36:*.wav=00;36:*.avi=01;35:*.mp4=01;35:*.mkv=01;35:*.pdf=00;32:*.md=00;33:*.yml=00;33:*.yaml=00;33:*.toml=00;33:*.json=00;33:*.go=00;36:*.rs=00;36:*.py=00;36:*.js=00;36:*.ts=00;36'"'"'' "$RC"; \
      fi; \
    done

# Starship prompt init (for both bash and zsh)
RUN if command -v starship >/dev/null 2>&1; then \
      for PAIR in "bash:{{.HomeDir}}/.bashrc" "zsh:{{.HomeDir}}/.zshrc"; do \
        SHELL_NAME="${PAIR%%:*}"; RC="${PAIR#*:}"; \
        if [ -f "$RC" ] && ! grep -q 'starship init' "$RC"; then \
          echo '[[ "$TERM" != "dumb" ]] && eval "$(starship init '"$SHELL_NAME"')"' >> "$RC"; \
        fi; \
      done; \
    fi

# Auto-start Zellij on interactive login (for cc-deck ws attach)
RUN for RC in {{.HomeDir}}/.bashrc {{.HomeDir}}/.zshrc; do \
      if [ -f "$RC" ] || [ "$(basename $RC)" = ".bashrc" ]; then \
        printf '\n# cc-deck: auto-start Zellij with cc-deck layout on interactive login\nif [ -z "$ZELLIJ" ] && [ -t 0 ]; then\n  export SHELL=/bin/{{.Shell}}\n  exec zellij --layout cc-deck attach --create cc-deck\nfi\n' >> "$RC"; \
      fi; \
    done
{{- end}}
