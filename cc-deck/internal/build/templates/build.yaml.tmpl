# cc-deck Setup Manifest
# This file describes the workspace to set up for Claude Code.
# Populate it using Claude Code commands:
#   /cc-deck.capture  - discover tools and settings from your local workspace
#   /cc-deck.build    - build container image or provision SSH target

version: 3

# Tool dependencies (resolved during build).
# Add manually or discover automatically with /cc-deck.capture.
# Each entry requires a name. Use install: "package" (default) for package
# manager installs, or install: "github-release" for GitHub release binaries.
# tools:
#   - name: "Go compiler >= 1.22"
#   - name: "Python 3.12 with uv package manager"
#   - name: "Node.js 22 LTS"
#   - name: cc-deck
#     install: github-release
#     repo: cc-deck/cc-deck
#   - name: cc-session
#     install: github-release
#     repo: cc-deck/cc-session

# Repositories analyzed for tool discovery (provenance tracking).
# Populated by /cc-deck.capture
# sources:
#   - url: https://github.com/org/repo
#     ref: main
#     path: /local/checkout/path
#     detected_tools: ["Go 1.23", "protoc >= 25.0"]
#     detected_from: [go.mod, buf.yaml, .github/workflows/ci.yml]

# Claude Code plugins to install.
# Populated by /cc-deck.capture
# plugins:
#   - name: sdd
#     source: marketplace                        # from official Anthropic marketplace
#   - name: custom-plugin
#     source: "github:org/marketplace-repo"       # GitHub-based custom marketplace
#     marketplace: custom-marketplace
#   - name: dev-plugin
#     source: directory                           # local dev plugin (skipped on remote)

# MCP server sidecars (for compose/k8s deployment).
# Populated by /cc-deck.capture
# mcp:
#   - name: github
#     image: ghcr.io/modelcontextprotocol/github-mcp:latest
#     transport: sse
#     port: 8000
#     auth:
#       type: token
#       env_vars: [GITHUB_TOKEN]
#     description: GitHub API access for issue and PR management

# User configuration to apply to the target.
# Populated by /cc-deck.capture
# settings:
#   shell: zsh                       # Shell to use: "zsh" (default) or "bash"
#   shell_rc: ./zshrc                # Custom shell config (appended to base rc file)
#   zellij_config: current           # "current" (copy local config.kdl), "vanilla", or a path
#   claude_md: ./CLAUDE.md           # Global Claude instructions (-> ~/.claude/CLAUDE.md)
#   claude_settings: ./settings.json # Claude preferences to merge (model, theme, etc.)
#   hooks: ./hooks.json              # Extra hooks to merge with cc-deck hooks
#   mcp_settings: ./mcp-settings.json     # npx-based MCP server configs to merge
#   cc_setup_mcp: ./cc-setup-mcp.json     # cc-setup MCP cache (-> ~/.config/cc-setup/mcp.json)
#   git_config:                            # Git identity (extracted from local git config)
#     user.name: "Your Name"
#     user.email: "you@example.com"
#   tool_configs:                          # Config files for detected tools (-> ~/.config/<target>)
#     - tool: starship
#       source: ./starship.toml
#       target: starship.toml              # relative to ~/.config/
#     - tool: helix
#       source: ./helix-config.toml
#       target: helix/config.toml

# Network domain groups for container workspaces.
# network:
#   allowed_domains:
#     - golang
#     - github

