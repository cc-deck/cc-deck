# cc-deck Build Manifest
# This file describes the container image to build for your Claude Code environment.
# Populate it using Claude Code commands: /cc-deck.extract, /cc-deck.plugin, /cc-deck.mcp
# Then generate the Containerfile: /cc-deck.containerfile

version: 1

image:
  name: {{.ImageName}}
  base: {{.BaseImage}}
  # tag: latest

# Tool dependencies (free-form text, resolved during Containerfile generation).
# Add manually or discover automatically with /cc-deck.extract
# tools:
#   - "Go compiler >= 1.22"
#   - "Python 3.12 with uv package manager"
#   - "Node.js 22 LTS"
#   - "protoc and buf CLI"
#   - "Rust stable toolchain"

# Repositories analyzed for tool discovery (provenance tracking).
# Populated by /cc-deck.extract
# sources:
#   - url: https://github.com/org/repo
#     ref: main
#     path: /local/checkout/path
#     detected_tools: ["Go 1.23", "protoc >= 25.0"]
#     detected_from: [go.mod, buf.yaml, .github/workflows/ci.yml]

# Claude Code plugins to install.
# Add with /cc-deck.plugin
# plugins:
#   - name: sdd
#     source: marketplace
#   - name: custom-plugin
#     source: "git:https://github.com/org/plugin.git"

# MCP server sidecars (for compose/k8s deployment).
# Add with /cc-deck.mcp
# mcp:
#   - name: github
#     image: ghcr.io/modelcontextprotocol/github-mcp:latest
#     transport: sse
#     port: 8000
#     auth:
#       type: token
#       env_vars: [GITHUB_TOKEN]
#     description: GitHub API access for issue and PR management

# Additional tools from GitHub releases.
# github_tools:
#   - repo: rhuss/cc-setup
#     binary: cc-setup
#   - repo: rhuss/cc-session
#     binary: cc-session

# User configuration to bake into the image.
# settings:
#   claude_md: ./CLAUDE.md           # Global Claude instructions (-> ~/.claude/CLAUDE.md)
#   claude_settings: ./settings.json # Claude preferences to merge (model, theme, etc.)
#   hooks: ./hooks.json              # Extra hooks to merge with cc-deck hooks
#   zellij_config: current           # "current" (copy local config.kdl), "vanilla", or a path
